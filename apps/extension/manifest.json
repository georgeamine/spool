{
  "manifest_version": 3,
  "name": "Spool - Screen Recorder",
  "key": "",
  "description": "Screen recorder for tab, window, or full screen capture.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "scripting",
    "identity",
    "activeTab",
    "tabs",
    "tabCapture",
    "desktopCapture",
    "offscreen",
    "downloads"
  ],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*", "https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Spool",
    "default_icon": {
      "16": "bobbin.png",
      "32": "bobbin.png",
      "48": "bobbin.png",
      "128": "bobbin.png"
    }
  },
  "icons": {
    "16": "bobbin.png",
    "32": "bobbin.png",
    "48": "bobbin.png",
    "128": "bobbin.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/offscreen.html",
        "src/overlay.html",
        "src/overlay.css",
        "src/overlay.js",
        "src/recording-result.html",
        "src/generated/recording-detail.css",
        "src/generated/recording-detail.js",
        "src/generated/recordings.css",
        "src/generated/recordings.js",
        "src/recording-store.js",
        "src/recording-title.js",
        "src/share-auth.js",
        "src/share-config.js",
        "src/uploads.html",
        "src/webcam-bubble.html",
        "src/webcam-bubble.css",
        "src/webcam-bubble.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
